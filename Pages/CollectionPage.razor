@page "/collections"

@using Snipster.Data;
@using Snipster.Services;
@using Snipster.Components
@inject IJSRuntime JSRuntime
@attribute [Authorize]



<div class="page-layout">
    <!-- Left Section: Collection List -->
    <div class="panel collection-panel @(isLeftPanelOpen ? "" : "collapsed")">
        <button class="toggle-btn" @onclick="ToggleLeftPanel">
            <i class="fa @(isLeftPanelOpen ? "fa-chevron-left" : "fa-chevron-right")"></i>
        </button>
        
        @if (isLeftPanelOpen)
        {
            <div class="panel-header">
                <h3><i class="fa fa-folder-open"></i> Collections</h3>
            </div>
            
            <!-- Tab buttons -->
            <div class="tab-buttons">
                <button class="tab-btn @(activeCollectionTab == "own" ? "active" : "")" @onclick="@(() => SwitchCollectionTab("own"))">
                    <i class="fa fa-folder"></i> Mine
                    @if (collections != null)
                    {
                        <span class="tab-count">@collections.Count</span>
                    }
                </button>
                <button class="tab-btn @(activeCollectionTab == "shared" ? "active" : "")" @onclick="@(() => SwitchCollectionTab("shared"))">
                    <i class="fa fa-share-alt"></i> Shared
                    @if (sharedCollections != null)
                    {
                        <span class="tab-count">@sharedCollections.Count</span>
                    }
                </button>
            </div>
            
            <div class="search-card-mini">
                <div class="search-input-wrapper">
                    <i class="fa fa-search search-icon"></i>
                    <input class="search-input" type="text" @bind="searchCollectionQuery" placeholder="Search..." />
                </div>
                <div class="search-actions-mini">
                    <button class="btn-search-mini" @onclick="OnSearchCollection">
                        <i class="fa fa-search"></i>
                    </button>
                    <button class="btn-clear-mini" @onclick="CancelSearchCollection">
                        <i class="fa fa-times"></i>
                    </button>
                </div>
            </div>
            
            @if (activeCollectionTab == "own")
            {
                <button class="btn-add-new" @onclick="ShowCreateCollectionModal">
                    <i class="fa fa-plus"></i> New Collection
                </button>
            }

            <div class="items-container">
                @if (activeCollectionTab == "own")
                {
                    @if (collections != null && collections.Any())
                    {
                        @foreach (var collection in PagedCollections)
                        {
                            <div class="item-card @(selectedCollectionId == collection.Id ? "active" : "")" @onclick="() => LoadSnippets(collection.Id)">
                                <div class="item-content">
                                    <i class="fa fa-folder item-icon"></i>
                                    <span class="item-title">@collection.Title</span>
                                </div>
                                <div class="item-actions">
                                    <button class="action-btn edit" @onclick:stopPropagation="true" @onclick="() => EditCollection(collection)" title="Edit">
                                        <i class="fa fa-edit"></i>
                                    </button>
                                    <button class="action-btn delete" @onclick:stopPropagation="true" @onclick="() => DeleteCollection(collection.Id)" title="Delete">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                        @if (CollectionsTotalPages > 1)
                        {
                            <div class="pagination-mini">
                                <button class="page-btn" @onclick="CollectionsFirstPage" disabled="@(collectionsCurrentPage == 1)">««</button>
                                <button class="page-btn" @onclick="CollectionsPreviousPage" disabled="@(collectionsCurrentPage == 1)">«</button>
                                <span>@collectionsCurrentPage/@CollectionsTotalPages</span>
                                <button class="page-btn" @onclick="CollectionsNextPage" disabled="@(collectionsCurrentPage == CollectionsTotalPages)">»</button>
                                <button class="page-btn" @onclick="CollectionsLastPage" disabled="@(collectionsCurrentPage == CollectionsTotalPages)">»»</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-mini">
                            <i class="fa fa-folder-open"></i>
                            <p>No collections yet</p>
                        </div>
                    }
                }
                else
                {
                    @if (sharedCollections != null && sharedCollections.Any())
                    {
                        @foreach (var sharedCollection in PagedSharedCollections)
                        {
                            <div class="item-card shared @(selectedCollectionId == sharedCollection.Id ? "active" : "")" @onclick="() => LoadSnippets(sharedCollection.Id)">
                                <div class="item-content">
                                    <i class="fa fa-share-alt item-icon shared"></i>
                                    <span class="item-title">@sharedCollection.Title</span>
                                </div>
                            </div>
                        }
                        @if (SharedCollectionsTotalPages > 1)
                        {
                            <div class="pagination-mini">
                                <button class="page-btn" @onclick="SharedCollectionsFirstPage" disabled="@(sharedCollectionsCurrentPage == 1)">««</button>
                                <button class="page-btn" @onclick="SharedCollectionsPreviousPage" disabled="@(sharedCollectionsCurrentPage == 1)">«</button>
                                <span>@sharedCollectionsCurrentPage/@SharedCollectionsTotalPages</span>
                                <button class="page-btn" @onclick="SharedCollectionsNextPage" disabled="@(sharedCollectionsCurrentPage == SharedCollectionsTotalPages)">»</button>
                                <button class="page-btn" @onclick="SharedCollectionsLastPage" disabled="@(sharedCollectionsCurrentPage == SharedCollectionsTotalPages)">»»</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-mini">
                            <i class="fa fa-share-alt"></i>
                            <p>No shared collections</p>
                        </div>
                    }
                }
            </div>
        }
    </div>

    <!-- Middle Section: Snippet List -->
    <div class="panel snippet-panel @(isMiddlePanelOpen ? "" : "collapsed")">
        <button class="toggle-btn" @onclick="ToggleMiddlePanel">
            <i class="fa @(isMiddlePanelOpen ? "fa-chevron-left" : "fa-chevron-right")"></i>
        </button>
        
        @if (isMiddlePanelOpen)
        {
            <div class="panel-header">
                <h3><i class="fa fa-code"></i> Snippets</h3>
            </div>
            
            <div class="search-card-mini">
                <div class="search-input-wrapper">
                    <i class="fa fa-search search-icon"></i>
                    <input class="search-input" type="text" @bind="searchSnippetQuery" placeholder="Search snippets..." />
                    <button class="filter-btn-mini @(IsFavouriteSearch ? "active" : "")" @onclick="() => SearchFavouriteSnippets()" title="Favorites only">
                        <i class="fa fa-star"></i>
                    </button>
                </div>
                <div class="search-actions-mini">
                    <button class="btn-search-mini" @onclick="OnSearchSnippet">
                        <i class="fa fa-search"></i>
                    </button>
                    <button class="btn-clear-mini" @onclick="CancelSearchSnippet">
                        <i class="fa fa-times"></i>
                    </button>
                </div>
            </div>
            
            <button class="btn-add-new" @onclick="ShowSnippetFields">
                <i class="fa fa-plus"></i> New Snippet
            </button>

            <div class="items-container">
                @if (snippets != null && snippets.Any())
                {
                    @foreach (var snippet in PagedSnippets)
                    {
                        <div class="item-card @(selectedSnippet?.Id == snippet.Id ? "active" : "")" @onclick="() => LoadSnippetDetails(snippet.Id)">
                            <div class="item-content">
                                <i class="fa fa-file-code item-icon"></i>
                                <div class="item-info">
                                    <span class="item-title">@snippet.Title</span>
                                    @if (!string.IsNullOrEmpty(snippet.Language))
                                    {
                                        <span class="language-tag">@snippet.Language</span>
                                    }
                                </div>
                            </div>
                            @if (selectedCollectionIsOwn)
                            {
                                <button class="action-btn favorite @(snippet.IsFavourite ? "active" : "")" @onclick:stopPropagation="true" @onclick="() => EditSnippetFavourite(snippet)" title="@(snippet.IsFavourite ? "Remove from favorites" : "Add to favorites")">
                                    <i class="fa fa-star"></i>
                                </button>
                            }
                        </div>
                    }
                    @if (SnippetsTotalPages > 1)
                    {
                        <div class="pagination-mini">
                            <button class="page-btn" @onclick="SnippetsFirstPage" disabled="@(snippetsCurrentPage == 1)">««</button>
                            <button class="page-btn" @onclick="SnippetsPreviousPage" disabled="@(snippetsCurrentPage == 1)">«</button>
                            <span>@snippetsCurrentPage/@SnippetsTotalPages</span>
                            <button class="page-btn" @onclick="SnippetsNextPage" disabled="@(snippetsCurrentPage == SnippetsTotalPages)">»</button>
                            <button class="page-btn" @onclick="SnippetsLastPage" disabled="@(snippetsCurrentPage == SnippetsTotalPages)">»»</button>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state-mini">
                        <i class="fa fa-code"></i>
                        <p>No snippets</p>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Right Section: Snippet Details/Editor -->
    <div class="panel editor-panel" style="flex: 1;">
        @if (isAddingSnippet)
        {
            <div class="editor-header">
                <h3><i class="fa fa-plus-circle"></i> Create New Snippet</h3>
            </div>
            
            <EditForm Model="newSnippet" OnValidSubmit="HandleValidSubmitNew" class="editor-form">
                <DataAnnotationsValidator />
                <ValidationSummary />
                
                <div class="form-row">
                    <div class="form-group flex-2">
                        <label><i class="fa fa-heading"></i> Title</label>
                        <input type="text" id="title" class="form-input" @bind="newSnippet.Title" placeholder="Snippet title" />
                    </div>
                    <div class="form-group flex-1">
                        <label><i class="fa fa-folder"></i> Collection</label>
                        <select id="collections" class="form-select" @bind="selectedCollectionIdCreate">
                            @foreach (var collection in collections)
                            {
                                <option value="@collection.Id">@collection.Title</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group flex-1">
                        <label><i class="fa fa-code"></i> Language</label>
                        <select id="language" class="form-select" @bind="newSnippet.Language" @bind:after="OnNewLanguageChanged">
                            <option value="">Select Language</option>
                            <option value="javascript">JavaScript</option>
                            <option value="typescript">TypeScript</option>
                            <option value="python">Python</option>
                            <option value="csharp">C#</option>
                            <option value="java">Java</option>
                            <option value="cpp">C++</option>
                            <option value="c">C</option>
                            <option value="html">HTML</option>
                            <option value="css">CSS</option>
                            <option value="sql">SQL</option>
                            <option value="json">JSON</option>
                            <option value="xml">XML</option>
                            <option value="bash">Bash/Shell</option>
                            <option value="powershell">PowerShell</option>
                            <option value="ruby">Ruby</option>
                            <option value="php">PHP</option>
                            <option value="go">Go</option>
                            <option value="rust">Rust</option>
                            <option value="swift">Swift</option>
                            <option value="kotlin">Kotlin</option>
                            <option value="yaml">YAML</option>
                            <option value="markdown">Markdown</option>
                            <option value="razor">Razor</option>
                            <option value="plaintext">Plain Text</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group flex-1">
                        <label><i class="fa fa-hashtag"></i> Hashtags</label>
                        <input type="text" id="hashtags" class="form-input" @bind="@newSnippet.HashtagsInput" placeholder="#tag1 #tag2 #tag3" />
                    </div>
                    <div class="form-group flex-1">
                        <label><i class="fa fa-share-alt"></i> Share with</label>
                        <input type="text" id="sharedemailadresses" class="form-input" @bind="newSnippet.SharedWithInput" placeholder="email1@example.com; email2@example.com" />
                    </div>
                </div>

                <div class="form-group code-editor-container">
                    <label><i class="fa fa-code"></i> Code</label>
                    <div id="createEditorContainer" class="monaco-editor-container"></div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary" disabled="@(!isFormValid)">
                        <i class="fa fa-plus"></i> Add Snippet
                    </button>
                </div>

            </EditForm>
        }
        else if (selectedSnippet != null)
        {
            <div class="editor-header">
                <h3><i class="fa fa-edit"></i> Edit Snippet</h3>
                @if (!string.IsNullOrEmpty(selectedSnippet.Language))
                {
                    <span class="language-badge">@selectedSnippet.Language</span>
                }
            </div>
            
            <EditForm Model="selectedSnippet" OnValidSubmit="HandleValidSubmitEdit" Context="formContext2" class="editor-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-row">
                    <div class="form-group flex-2">
                        <label><i class="fa fa-heading"></i> Title</label>
                        <input type="text" id="title" class="form-input" @bind="selectedSnippet.Title" placeholder="Snippet title" disabled="@(!selectedCollectionIsOwn)" />
                    </div>
                    <div class="form-group flex-1">
                        <label><i class="fa fa-code"></i> Language</label>
                        <select id="editLanguage" class="form-select" @bind="selectedSnippet.Language" @bind:after="OnEditLanguageChanged" disabled="@(!selectedCollectionIsOwn)">
                            <option value="">Select...</option>
                            <option value="javascript">JavaScript</option>
                            <option value="typescript">TypeScript</option>
                            <option value="python">Python</option>
                            <option value="csharp">C#</option>
                            <option value="java">Java</option>
                            <option value="cpp">C++</option>
                            <option value="c">C</option>
                            <option value="html">HTML</option>
                            <option value="css">CSS</option>
                            <option value="sql">SQL</option>
                            <option value="json">JSON</option>
                            <option value="xml">XML</option>
                            <option value="bash">Bash/Shell</option>
                            <option value="powershell">PowerShell</option>
                            <option value="ruby">Ruby</option>
                            <option value="php">PHP</option>
                            <option value="go">Go</option>
                            <option value="rust">Rust</option>
                            <option value="swift">Swift</option>
                            <option value="kotlin">Kotlin</option>
                            <option value="yaml">YAML</option>
                            <option value="markdown">Markdown</option>
                            <option value="razor">Razor</option>
                            <option value="plaintext">Plain Text</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group flex-1">
                        <label><i class="fa fa-hashtag"></i> Hashtags</label>
                        <input type="text" id="hashtags" class="form-input" @bind="@selectedSnippet.HashtagsInput" placeholder="#tag1 #tag2 #tag3" disabled="@(!selectedCollectionIsOwn)" />
                    </div>
                    <div class="form-group flex-1">
                        <label><i class="fa fa-share-alt"></i> Share with</label>
                        <input type="text" id="sharedemailadresses" class="form-input" @bind="selectedSnippet.SharedWithInput" placeholder="email1@example.com; email2@example.com" disabled="@(!selectedCollectionIsOwn)" />
                    </div>
                </div>

                <div class="form-group code-editor-container">
                    <label><i class="fa fa-code"></i> Code</label>
                    <div id="editEditorContainer" class="monaco-editor-container"></div>
                </div>
                
                @if (selectedCollectionIsOwn)
                {
                    <div class="form-actions">
                        <button type="submit" class="btn-primary" disabled="@(!isFormValid)">
                            <i class="fa fa-save"></i> Save Changes
                        </button>
                        <button type="button" class="btn-danger" @onclick="() => DeleteSnippet(selectedSnippet.Id)">
                            <i class="fa fa-trash"></i> Delete
                        </button>
                    </div>
                }
            </EditForm>
        }
        else
        {
            <div class="empty-state-editor">
                <i class="fa fa-code"></i>
                <h3>No snippet selected</h3>
                <p>Select a snippet from the list or create a new one</p>
            </div>
        }
    </div>
</div>





<!-- Modal for creating a new collection -->
<Modal @ref="createCollectionModal" Title="Create New Collection">
    <EditForm Model="newCollection" OnValidSubmit="async () => await HandleCreateCollection()">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="modal-body-edit">
            <div class="form-group">
                <label>Title:</label>
                <InputText class="form-input" @bind-Value="newCollection.Title" />
            </div>


            <div class="form-group">
                <label class="inline">
                    Public:
                    <InputCheckbox class="checkbox-element" @bind-Value="newCollection.IsPublic" />
                </label>
            </div>

            <div class="form-group">
                <button class="create-collection-btn" type="submit">Create</button>
            </div>

        </div>
    </EditForm>
</Modal>

<!-- Modal for editing a collection -->
<Modal @ref="editCollectionModal" Title="Edit Collection">
    <EditForm Model="editCollection" OnValidSubmit="async () => await HandleEditCollection()">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="modal-body-edit">
            <div class="form-group">
                <label>Title:</label>
                <InputText class="form-input" @bind-Value="editCollection.Title" />
            </div>

            <div class="form-group">
                <label class="inline">
                    Public:
                    <InputCheckbox class="checkbox-element" @bind-Value="editCollection.IsPublic" />
                </label>
            </div>

            <div class="form-group">
                <button class="create-collection-btn" type="submit">Save</button>
            </div>
        </div>
    </EditForm>
</Modal>

<Modal @ref="spinnerModal">

</Modal>



